{
  "expo": {
    "name": "Shape Run",
    "slug": "shape-run",
    "scheme": "shaperun",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.inha.shaperun"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.inha.shaperun"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "러닝 중 현재 위치를 기록하기 위해 위치 권한이 필요합니다.",
          "locationAlwaysAndWhenInUsePermission": "화면이 꺼진 상태에서도 러닝 경로를 기록하기 위해 항상 위치 권한이 필요합니다.",
          "isIosBackgroundLocationEnabled": true,
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ]
    ],
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
